{
  "functions": {
    "api/chat.js": {
      "includeFiles": "api/context/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/report",
      "destination": "/frontend/report.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}

