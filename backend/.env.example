# Copy to backend/.env and edit as needed
APP_ENV=dev
LOG_LEVEL=INFO

# Storage
DATA_DIR=/data

# Database
# In docker-compose, DATABASE_URL is injected automatically for the api service.
DATABASE_URL=postgresql+psycopg://ddv:ddv@localhost:5432/ddv

# Shared-password gate (stored in Supabase)
# Create table: app_secrets(key text primary key, value text not null)
# Store bcrypt hash at key="shared_password_hash"
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_TABLE=app_secrets
SUPABASE_SHARED_PASSWORD_KEY=shared_password_hash

# Token issued after password verification (change in prod)
ACCESS_TOKEN_SECRET=dev-change-me
ACCESS_TOKEN_TTL_SECONDS=1800

# CORS (comma-separated). For local static frontend, "*" is OK.
CORS_ORIGINS=*

# OpenAI
OPENAI_API_KEY=

# Optional: store OpenAI key in Supabase (instead of env var)
# Insert into app_secrets: key='openai_api_key', value='<your key>'

# Extraction tuning
FUZZY_MATCH_ENABLED=true
FUZZY_MATCH_THRESHOLD=85
LOW_CONFIDENCE_THRESHOLD=0.7

